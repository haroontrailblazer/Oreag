# Postgres connection (Supabase -> Project Settings -> Database -> Connection string).
# Use the session pooler URI and the postgresql+psycopg:// scheme, e.g.
# postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Supabase project (Project Settings -> API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# JWT verification: "jwks" (default, new Supabase projects) or "hs256" (legacy).
JWT_MODE=jwks
# Only needed when JWT_MODE=hs256 (Project Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=

# Providers
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Comma-separated origins allowed to call this API from a browser
CORS_ORIGINS=http://localhost:3000
